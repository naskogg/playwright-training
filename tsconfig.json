{
  "compilerOptions": {
    "target": "ESNext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "@playwright/test"],
    "paths": {
      "@pages/*": ["./pages/*"],
      "@fixtures/*": ["./fixtures/*"]
    }
  },
  "include": ["tests/**/*.ts", "fixtures/**/*.ts", "pages/**/*.ts", "playwright.config.ts"]
}
